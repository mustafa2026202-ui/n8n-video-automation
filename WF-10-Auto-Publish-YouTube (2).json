        "jsCode": "const item = $input.first().json;\nconst fileName = item.name || 'untitled';\nconst baseName = fileName.replace(/\\.[^.]+$/, '');\nconst cleanTitle = baseName.replace(/[-_]/g, ' ').trim();\nconst requestId = 'YT-' + Date.now();\nconst timestamp = new Date().toISOString();\nconst description = cleanTitle + '\\n\\n#Shorts #Auto #Video\\n\\nPublished: ' + timestamp;\nreturn [{ json: { request_id: requestId, file_id: item.id, file_name: fileName, title: cleanTitle, description: description, hashtags: ['Shorts','Auto','Video'], timestamp: timestamp }, binary: $input.first().binary }];"

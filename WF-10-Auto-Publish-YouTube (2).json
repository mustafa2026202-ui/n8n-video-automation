    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst item = $input.first();\n\nconst TMPDIR = 'C:\\\\Users\\\\3D\\\\Videos\\\\n8n_tmp';\nconst INPUT = path.join(TMPDIR, 'input_video.mp4');\n\n// Create directory if not exists\nif (!fs.existsSync(TMPDIR)) {\n  fs.mkdirSync(TMPDIR, { recursive: true });\n}\n\n// Get binary data\nconst binaryData = item.binary?.video_binary;\nif (!binaryData) throw new Error('No video_binary field found in input');\n\n// Write file using Buffer\nconst buf = Buffer.from(binaryData.data, 'base64');\nfs.writeFileSync(INPUT, buf);\n\nif (!fs.existsSync(INPUT)) throw new Error('File was not written: ' + INPUT);\n\nreturn [{\n  json: {\n    ...item.json,\n    tmp_input_path: INPUT\n  },\n  binary: item.binary\n}];"
      },

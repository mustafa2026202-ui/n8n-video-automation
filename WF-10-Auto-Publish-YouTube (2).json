      "parameters": {
        "jsCode": "// FFmpeg availability check\n// Note: child_process must be enabled in n8n .env:\n// NODE_FUNCTION_ALLOW_BUILTIN=child_process,fs\n//\n// This node verifies setup and passes data through\n// Real FFmpeg check happens in FFmpeg_Edit_Video\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    ffmpeg_check: 'pending_runtime_check',\n    setup_note: 'Ensure NODE_FUNCTION_ALLOW_BUILTIN=child_process,fs is in .env'\n  },\n  binary: item.binary\n}));"
      },
      "id": "check-ffmpeg-001",
      "name": "Check_FFmpeg",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        928,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst item = $input.first();\n\nconst TMPDIR = 'C:\\\\Users\\\\3D\\\\Videos\\\\n8n_tmp';\nconst INPUT = path.join(TMPDIR, 'input_video.mp4');\nconst OUTPUT = path.join(TMPDIR, 'output_video.mp4');\n\nif (!fs.existsSync(INPUT)) throw new Error('Input not found: ' + INPUT);\n\nif (fs.existsSync(OUTPUT)) fs.unlinkSync(OUTPUT);\n\nlet duration = 0;\ntry {\n  duration = parseFloat(\n    execSync('ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 \"' + INPUT + '\"', { timeout: 30000 }).toString().trim()\n  ) || 0;\n} catch(e) { duration = 0; }\n\nconst SCALE = 'scale=1080:1920:force_original_aspect_ratio=decrease,pad=1080:1920:(ow-iw)/2:(oh-ih)/2:black';\nconst trimOpt = duration > 30 ? '-t 30' : '';\nconst cmd = 'ffmpeg -y -i \"' + INPUT + '\" ' + trimOpt + ' -vf \"' + SCALE + '\" -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 128k \"' + OUTPUT + '\" 2>&1';\n\ntry { execSync(cmd, { timeout: 300000 }); }\ncatch(e) {\n  const err = e.stdout ? e.stdout.toString().slice(-800) : e.message;\n  if (!fs.existsSync(OUTPUT)) throw new Error('FFmpeg failed: ' + err);\n}\n\nif (!fs.existsSync(OUTPUT)) throw new Error('FFmpeg output not created: ' + OUTPUT);\n\nreturn [{\n  json: {\n    ...item.json,\n    ffmpeg_output_path: OUTPUT,\n    ffmpeg_original_duration: duration,\n    ffmpeg_was_trimmed: duration > 30,\n    ffmpeg_output_size_bytes: fs.statSync(OUTPUT).size\n  },\n  binary: item.binary\n}];"
      },
